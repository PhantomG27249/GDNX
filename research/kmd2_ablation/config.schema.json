{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/kmd2-ablation/config.schema.json",
  "title": "Portable KMD-2 ablation experiment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "suite_version", "backend", "qwen", "baseline",
    "mechanism", "variant", "task", "seeds", "budget", "optimizer",
    "schedule", "model", "lengths", "evaluation", "thresholds",
    "promotion", "protected_metrics", "device_preferences",
    "dtype_preferences", "required_stage", "cache", "runtime"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "suite_version": {"const": "1.0.0"},
    "backend": {"enum": ["tiny", "qwen"]},
    "qwen": {"$ref": "#/$defs/qwen"},
    "baseline": {"type": "string", "minLength": 1},
    "mechanism": {"type": "string", "minLength": 1},
    "variant": {"type": "string", "minLength": 1},
    "task": {"$ref": "#/$defs/task"},
    "seeds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "integer", "minimum": 0}
    },
    "budget": {"$ref": "#/$defs/budget"},
    "optimizer": {"$ref": "#/$defs/optimizer"},
    "schedule": {"$ref": "#/$defs/schedule"},
    "model": {"$ref": "#/$defs/model"},
    "lengths": {"$ref": "#/$defs/lengths"},
    "evaluation": {"$ref": "#/$defs/evaluation"},
    "thresholds": {"$ref": "#/$defs/thresholds"},
    "promotion": {"$ref": "#/$defs/promotion"},
    "protected_metrics": {
      "type": "array",
      "items": {"$ref": "#/$defs/protectedMetric"}
    },
    "device_preferences": {
      "type": "array",
      "minItems": 1,
      "items": {"enum": ["cpu", "cuda"]}
    },
    "dtype_preferences": {
      "type": "array",
      "minItems": 1,
      "items": {"enum": ["float32", "bfloat16"]}
    },
    "required_stage": {"type": "string", "minLength": 1},
    "cache": {"$ref": "#/$defs/cache"},
    "runtime": {"$ref": "#/$defs/runtime"},
    "architecture": {"$ref": "#/$defs/architecture"}
  },
  "allOf": [
    {
      "if": {"properties": {"architecture": {"properties": {"arm_id": {"enum": ["gdn2-mimo-r4-braid-shared-hola-w64", "gdn2-mimo-r4-braid-four-state-hola-w64"]}}, "required": ["arm_id"]}}, "required": ["architecture"]},
      "then": {"properties": {"task": {"properties": {"params": {
        "required": ["input_rank", "output_rank", "read_topology", "read_paths", "state_input_mode", "lookahead", "qk_contract"],
        "properties": {
          "input_rank": {"const": 4}, "output_rank": {"const": 4},
          "read_topology": {"enum": ["shared_state_outputs", "full_cross_state"]},
          "read_paths": {"enum": [4, 16]}, "state_input_mode": {"const": "trapezoid"},
          "lookahead": {"type": "boolean"},
          "qk_contract": {"enum": ["affine_diagonal_plus_additive_identity_init", "gdn_unit_directional_affine_postrenorm_v1"]}
          ,"lambda_spec": {"type": "number", "minimum": 0}
          ,"lambda_gate": {"type": "number", "minimum": 0}
          ,"specialization_updates": {"type": "integer", "minimum": 0}
        }
      }}, "required": ["params"]}}}
    },
    {
      "if": {"properties": {"architecture": {"properties": {"arm_id": {"const": "gdn2-mimo-r4-braid-shared-hola-w64"}}, "required": ["arm_id"]}}, "required": ["architecture"]},
      "then": {"properties": {"task": {"properties": {"params": {"properties": {"read_topology": {"const": "shared_state_outputs"}, "read_paths": {"const": 4}, "lookahead": {"const": true}, "qk_contract": {"const": "affine_diagonal_plus_additive_identity_init"}}}}}}}
    },
    {
      "if": {"properties": {"architecture": {"properties": {"arm_id": {"const": "gdn2-mimo-r4-braid-four-state-hola-w64"}}, "required": ["arm_id"]}}, "required": ["architecture"]},
      "then": {"properties": {"task": {"properties": {"params": {"required": ["lambda_spec", "lambda_gate", "specialization_updates"], "properties": {"read_topology": {"const": "full_cross_state"}, "read_paths": {"const": 16}, "lookahead": {"const": false}, "qk_contract": {"const": "gdn_unit_directional_affine_postrenorm_v1"}, "lambda_spec": {"exclusiveMinimum": 0}, "lambda_gate": {"exclusiveMinimum": 0}, "specialization_updates": {"type": "integer", "minimum": 1}}}}}}}
    }
  ],
  "$defs": {
    "architecture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["arm_id", "registry_sha256", "model_tree_sha256", "ordered_examples_sha256", "pretraining_checkpoint_sha256"],
      "properties": {
        "arm_id": {"enum": ["stock", "kmd2-r1", "rot-off", "rot-constant", "rot-noncumulative", "rot-fixed-rope", "rot-moving-frame-oracle", "conv-off", "trapezoid", "qk-bc-additive", "qk-diagonal", "qk-constant-coordinate-oracle", "lookahead", "state-64x128", "state-256x128", "rout-4", "mimo-r2", "mimo-r4", "gdn2-channel-r1", "cache-block-only-w0", "cache-surprise-w64", "cache-recency-w64", "cache-coupled-w64", "cache-residual-w64", "cache-write-value-w64", "cache-reservoir-w64", "cache-per-slot-read-w64", "cache-unbounded-oracle", "gdn2-mimo-r4-braid-shared-hola-w64", "gdn2-mimo-r4-braid-four-state-hola-w64"]},
        "registry_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "model_tree_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "ordered_examples_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "pretraining_checkpoint_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "qwen": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_asset", "tokenizer_asset", "run_mode", "streaming", "decode",
        "packing", "padding", "attention_mask"
      ],
      "properties": {
        "model_asset": {"type": "string", "minLength": 1},
        "tokenizer_asset": {"type": "string", "minLength": 1},
        "run_mode": {"enum": ["reliance", "heal", "initial_exact_cache"]},
        "streaming": {"type": "boolean"},
        "decode": {"type": "boolean"},
        "packing": {"type": "boolean"},
        "padding": {"enum": ["none"]},
        "attention_mask": {"enum": ["none", "all_ones"]}
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "params"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "params": {"type": "object"}
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tokens", "updates"],
      "properties": {
        "tokens": {"type": "integer", "minimum": 1},
        "updates": {"type": "integer", "minimum": 1}
      }
    },
    "optimizer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "learning_rate", "betas", "eps", "weight_decay"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "learning_rate": {"type": "number", "exclusiveMinimum": 0},
        "betas": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {"type": "number", "minimum": 0, "exclusiveMaximum": 1}
        },
        "eps": {"type": "number", "exclusiveMinimum": 0},
        "weight_decay": {"type": "number", "minimum": 0}
      }
    },
    "schedule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "warmup_updates"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "warmup_updates": {"type": "integer", "minimum": 0}
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hidden_size", "num_layers", "num_heads", "state_key_dim",
        "state_value_dim", "ffn_dim", "ffn_match_lower", "ffn_match_upper"
      ],
      "properties": {
        "hidden_size": {"type": "integer", "minimum": 1},
        "num_layers": {"type": "integer", "minimum": 1},
        "num_heads": {"type": "integer", "minimum": 1},
        "state_key_dim": {"type": "integer", "minimum": 1},
        "state_value_dim": {"type": "integer", "minimum": 1},
        "ffn_dim": {"type": "integer", "minimum": 8, "multipleOf": 8},
        "ffn_match_lower": {"type": "integer", "minimum": 8, "multipleOf": 8},
        "ffn_match_upper": {"type": "integer", "minimum": 8, "multipleOf": 8}
      }
    },
    "lengths": {
      "type": "object",
      "additionalProperties": false,
      "required": ["curriculum", "extrapolation"],
      "properties": {
        "curriculum": {
          "type": "array", "minItems": 1,
          "items": {"type": "integer", "minimum": 1}
        },
        "extrapolation": {
          "type": "array", "minItems": 1,
          "items": {"type": "integer", "minimum": 1}
        }
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_metric", "direction"],
      "properties": {
        "primary_metric": {"type": "string", "minLength": 1},
        "direction": {"enum": ["maximize", "minimize"]}
      }
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min_useful_addition", "min_reliance", "equivalence_tolerance",
        "harm_threshold", "synergy_threshold"
      ],
      "properties": {
        "min_useful_addition": {"type": "number", "exclusiveMinimum": 0},
        "min_reliance": {"type": "number", "minimum": 0},
        "equivalence_tolerance": {"type": "number", "minimum": 0},
        "harm_threshold": {"type": "number", "minimum": 0},
        "synergy_threshold": {"type": "number", "minimum": 0}
      }
    },
    "promotion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min_gate_mean", "min_gate_max", "min_persistent_hit_rate",
        "min_conditional_read_accuracy", "min_shuffled_cache_dependence",
        "min_adjacent_capacity_lcb"
      ],
      "properties": {
        "min_gate_mean": {"type": "number", "minimum": 0, "maximum": 1},
        "min_gate_max": {"type": "number", "minimum": 0, "maximum": 1},
        "min_persistent_hit_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "min_conditional_read_accuracy": {"type": "number", "minimum": 0, "maximum": 1},
        "min_shuffled_cache_dependence": {"type": "number", "minimum": 0, "maximum": 1},
        "min_adjacent_capacity_lcb": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "protectedMetric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "max_regression"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "max_regression": {"type": "number", "minimum": 0}
      }
    },
    "cache": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "width", "block_size", "score", "read", "read_init", "eps_cache",
        "coordinate_frame", "pre_rotation_diagnostic", "storage_dtype",
        "compute_dtype", "inclusive", "tie_policy", "lr_cache",
        "weight_decay_cache"
      ],
      "properties": {
        "width": {"type": "integer", "minimum": 0},
        "block_size": {"type": "integer", "minimum": 1},
        "score": {
          "enum": [
            "exact_outer", "coupled_paper", "residual_only", "write_value",
            "recency", "reservoir", "future_query_oracle"
          ]
        },
        "read": {"enum": ["unit_l2", "fixed_temperature", "rmsnorm"]},
        "read_init": {"enum": ["gamma_one_sink_zero_amplitude_zero", "hola_gate_logit_v2_minus4"]},
        "eps_cache": {"type": "number", "exclusiveMinimum": 0},
        "coordinate_frame": {"enum": ["rotated_recurrence", "pre_rotation"]},
        "pre_rotation_diagnostic": {"type": "boolean"},
        "storage_dtype": {"enum": ["fp32", "bf16"]},
        "compute_dtype": {"const": "fp32"},
        "inclusive": {"const": true},
        "tie_policy": {"const": "score_desc_position_desc"},
        "lr_cache": {"type": "number", "exclusiveMinimum": 0},
        "weight_decay_cache": {"const": 0.0}
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["output_path", "device_ordinal"],
      "properties": {
        "output_path": {"type": "string", "minLength": 1},
        "device_ordinal": {"type": "integer", "minimum": 0}
      }
    }
  }
}
